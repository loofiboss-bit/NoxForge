    "panel-background": ["hint-top-margin", "hint-right-margin", "hint-bottom-margin", "hint-left-margin", "hint-top-inset", "hint-right-inset", "hint-bottom-inset", "hint-left-inset"],
    "scrollbar": ["hint-scrollbar-size"],
    "slider": ["hint-handle-size"],
    "switch": ["hint-handle-size"]
