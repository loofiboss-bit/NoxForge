#!/usr/bin/env python3
"""Read-only NoxForge installation and session diagnostics."""

from __future__ import annotations

import argparse
import configparser
import json
import os
import platform
import re
import subprocess
import sys
from pathlib import Path
from typing import Any

THEME_ID = "io.github.loofiboss.noxforge.desktop"
COMPONENTS = {
    "global-theme": ("plasma/look-and-feel", THEME_ID, "metadata.json"),
    "plasma-style": ("plasma/desktoptheme", THEME_ID, "metadata.json"),
    "color-scheme": ("color-schemes", "", "NoxForgeDark.colors"),
    "aurorae": ("aurorae/themes", THEME_ID, "metadata.desktop"),
    "icons": ("icons", "NoxForge", "index.theme"),
    "cursors": ("icons", "NoxForge-Cursors", "index.theme"),
    "sounds": ("sounds", "NoxForge", "index.theme"),
    "wallpaper": ("wallpapers", "NoxForge", "metadata.json"),
    "kwin-switcher": ("kwin/tabbox", THEME_ID, "metadata.json"),
    "sddm": ("sddm/themes", "NoxForge", "metadata.desktop"),
}
ACTIVE_CONFIG = {
    "colorScheme": ("kdeglobals", "General", "ColorScheme"),
    "icons": ("kdeglobals", "Icons", "Theme"),
    "plasmaStyle": ("plasmarc", "Theme", "name"),
    "cursorTheme": ("kcminputrc", "Mouse", "cursorTheme"),
    "aurorae": ("kwinrc", "org.kde.kdecoration2", "theme"),
    "kwinSwitcher": ("kwinrc", "TabBox", "LayoutName"),
    "splash": ("ksplashrc", "KSplash", "Theme"),
}
SEMVER = re.compile(r"^\d+\.\d+\.\d+$")


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Inspect NoxForge without changing settings or files."
    )
    parser.add_argument(
        "--root",
        type=Path,
        default=Path("/"),
        help="inspect an absolute staged or system root (default: /)",
    )
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    return parser.parse_args()


def data_roots(root: Path) -> list[Path]:
    if root != Path("/"):
        return [root / "usr/local/share", root / "usr/share"]
    roots: list[Path] = []
    configured = os.environ.get("XDG_DATA_HOME")
    if configured:
        roots.append(Path(configured))
    else:
        roots.append(Path.home() / ".local/share")
    roots.extend((Path("/usr/local/share"), Path("/usr/share")))
    return roots


def component_path(data_root: Path, definition: tuple[str, str, str]) -> Path:
    category, directory, marker = definition
    path = data_root / category
    if directory:
        path /= directory
    return path / marker


def metadata_version(path: Path) -> str | None:
    if path.name == "metadata.json":
        try:
            value = json.loads(path.read_text(encoding="utf-8"))["KPlugin"]["Version"]
        except (KeyError, TypeError, json.JSONDecodeError, OSError):
            return None
        return value if isinstance(value, str) and SEMVER.fullmatch(value) else None
    if path.name == "metadata.desktop":
        parser = configparser.ConfigParser(interpolation=None)
        try:
            parser.read(path, encoding="utf-8")
        except (configparser.Error, OSError):
            return None
        for section, key in (
            ("Desktop Entry", "X-KDE-PluginInfo-Version"),
            ("SddmGreeterTheme", "Version"),
        ):
            if parser.has_option(section, key):
                value = parser.get(section, key)
                return value if SEMVER.fullmatch(value) else None
    return None


def expected_version(root: Path) -> str | None:
    candidates = [root / "usr/share/noxforge/VERSION"]
    repository_version = Path(__file__).resolve().parents[1] / "VERSION"
    candidates.append(repository_version)
    for path in candidates:
        try:
            value = path.read_text(encoding="utf-8").strip()
        except OSError:
            continue
        if SEMVER.fullmatch(value):
            return value
    return None


def package_version(root: Path) -> str | None:
    # rpm --root may create a database or lock file in an otherwise read-only
    # staging tree. Component metadata remains authoritative for --root checks.
    if root != Path("/"):
        return None
    command = ["rpm"]
    command.extend(("-q", "--qf", "%{VERSION}-%{RELEASE}", "noxforge"))
    try:
        result = subprocess.run(
            command,
            check=False,
            capture_output=True,
            text=True,
            timeout=5,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return None
    return result.stdout.strip() if result.returncode == 0 else None


def qt_plugin_paths(root: Path) -> list[Path]:
    candidates: list[Path] = []
    for libdir in ("lib64", "lib"):
        candidate = root / f"usr/{libdir}/qt6/plugins/styles/libnoxforge6.so"
        if candidate.is_file():
            candidates.append(candidate)
    return candidates


def read_active_components() -> dict[str, str]:
    config_root = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    active: dict[str, str] = {}
    for label, (filename, section, key) in ACTIVE_CONFIG.items():
        parser = configparser.ConfigParser(interpolation=None)
        try:
            parser.read(config_root / filename, encoding="utf-8")
        except (configparser.Error, OSError):
            continue
        if parser.has_option(section, key):
            active[label] = parser.get(section, key)
    return active


def build_report(root: Path) -> dict[str, Any]:
    roots = data_roots(root)
    components: dict[str, dict[str, Any]] = {}
    versions: set[str] = set()
    for name, definition in COMPONENTS.items():
        matches = [
            component_path(candidate, definition)
            for candidate in roots
            if component_path(candidate, definition).is_file()
        ]
        discovered_versions = sorted(
            {
                version
                for match in matches
                if (version := metadata_version(match)) is not None
            }
        )
        versions.update(discovered_versions)
        components[name] = {
            "found": bool(matches),
            "copies": len(matches),
            "versions": discovered_versions,
        }

    plugins = qt_plugin_paths(root)
    components["qt-style"] = {
        "found": bool(plugins),
        "copies": len(plugins),
        "versions": [],
    }

    expected = expected_version(root)
    mixed = len(versions) > 1 or (
        expected is not None and any(version != expected for version in versions)
    )
    missing = sorted(name for name, state in components.items() if not state["found"])
    complete = not missing and not mixed
    if missing:
        next_action = "Install or reinstall the NoxForge RPM, then run noxforge-doctor again."
    elif mixed:
        next_action = "Remove mixed source/user copies, reinstall one NoxForge RPM version, and rerun the doctor."
    else:
        next_action = "Installation is complete. Select NoxForge explicitly in System Settings if desired."

    report: dict[str, Any] = {
        "status": "ok" if complete else "incomplete",
        "packageVersion": package_version(root),
        "expectedVersion": expected,
        "componentVersions": sorted(versions),
        "mixedVersions": mixed,
        "missing": missing,
        "components": components,
        "nextAction": next_action,
        "session": {
            "type": os.environ.get("XDG_SESSION_TYPE", "unknown"),
            "kde": os.environ.get("KDE_FULL_SESSION", "unknown"),
            "wayland": "present" if os.environ.get("WAYLAND_DISPLAY") else "absent",
            "scale": os.environ.get("QT_SCALE_FACTOR", "system-default"),
            "kernel": platform.release(),
        },
    }
    if root == Path("/"):
        report["active"] = read_active_components()
    else:
        report["active"] = {}
    return report


def print_human(report: dict[str, Any]) -> None:
    print(f"NoxForge doctor: {report['status']}")
    print(f"Package: {report['packageVersion'] or 'not registered'}")
    print(f"Expected version: {report['expectedVersion'] or 'unknown'}")
    for name, state in report["components"].items():
        label = "found" if state["found"] else "missing"
        suffix = f" ({', '.join(state['versions'])})" if state["versions"] else ""
        print(f"  {name}: {label}{suffix}")
    if report["active"]:
        print("Active settings (read-only):")
        for name, value in sorted(report["active"].items()):
            print(f"  {name}: {value}")
    session = report["session"]
    print(
        "Session: "
        f"{session['type']}, KDE={session['kde']}, Wayland={session['wayland']}, "
        f"scale={session['scale']}, kernel={session['kernel']}"
    )
    print(f"Next action: {report['nextAction']}")


def main() -> int:
    arguments = parse_args()
    root = arguments.root
    if not root.is_absolute():
        print("--root must be an absolute path", file=sys.stderr)
        return 2
    report = build_report(root)
    if arguments.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print_human(report)
    return 0 if report["status"] == "ok" else 1


if __name__ == "__main__":
    raise SystemExit(main())
